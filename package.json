{
	"name": "chaching",
	"version": "1.6.0",
	"description": "Local multi-provider AI token spend dashboard for Claude Code, Codex, OpenCode, and Cursor.",
	"private": false,
	"type": "module",
	"license": "PolyForm-Noncommercial-1.0.0",
	"author": "Rai Butera",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/rbutera/chaching.git"
	},
	"homepage": "https://github.com/rbutera/chaching#readme",
	"bugs": {
		"url": "https://github.com/rbutera/chaching/issues"
	},
	"bin": {
		"chaching": "bin/chaching.js"
	},
	"files": [
		"bin/",
		"build/",
		"dist/",
		"static/",
		"CONFIG.md",
		"config.example.json",
		"LICENSE",
		"README.md"
	],
	"engines": {
		"node": ">=24.16.0"
	},
	"keywords": [
		"ai",
		"tokens",
		"claude-code",
		"codex",
		"opencode",
		"cursor",
		"dashboard"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"dev": "vite dev",
		"gen:favicons": "tsx scripts/gen-favicons.ts",
		"gen:og": "tsx scripts/gen-og.ts",
		"gen:assets": "npm run gen:favicons && npm run gen:og",
		"prebuild": "npm run gen:assets",
		"build": "npm run build:sk && npm run build:cli",
		"build:sk": "vite build",
		"build:cli": "tsup",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "npm run build",
		"prepublishOnly": "npm test && npm run check",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"pretest": "npm run build:cli",
		"test": "vitest run",
		"start": "node bin/chaching.js",
		"pack:dry": "npm pack --dry-run"
	},
	"devDependencies": {
		"@fontsource/inter": "5.2.8",
		"@fontsource/jetbrains-mono": "5.2.8",
		"@resvg/resvg-js": "2.6.2",
		"@sveltejs/adapter-node": "5.5.4",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@testing-library/jest-dom": "6.9.1",
		"@testing-library/svelte": "5.3.1",
		"@testing-library/user-event": "14.6.1",
		"@types/canvas-confetti": "1.9.0",
		"@types/culori": "4.0.1",
		"@types/d3-array": "3.2.2",
		"@types/d3-scale": "4.0.9",
		"@types/d3-shape": "3.1.8",
		"@types/d3-time": "3.0.4",
		"@types/node": "24.13.2",
		"@types/react": "19.2.17",
		"culori": "4.0.2",
		"ink-testing-library": "4.0.0",
		"jsdom": "29.1.1",
		"satori": "0.26.0",
		"sharp": "0.35.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tsup": "8.5.1",
		"tsx": "4.22.4",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"vitest": "4.1.7"
	},
	"dependencies": {
		"@clack/prompts": "1.5.1",
		"@tanstack/svelte-table": "9.0.0-beta.12",
		"@tanstack/svelte-virtual": "3.13.29",
		"ansi-styles": "6.2.3",
		"canvas-confetti": "1.9.4",
		"d3-array": "3.2.4",
		"d3-scale": "4.0.2",
		"d3-shape": "3.2.0",
		"d3-time": "3.1.0",
		"ink": "7.0.5",
		"react": "19.2.7"
	},
	"optionalDependencies": {
		"@resvg/resvg-js": "2.6.2",
		"satori": "0.26.0"
	}
}
